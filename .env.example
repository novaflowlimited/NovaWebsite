# PostgreSQL (required). Local Docker maps host port 5433 → container 5432 (see docker-compose.yml).
DATABASE_URL="postgresql://novaflow:novaflow@localhost:5433/novaflow?schema=public"
# Hosted (Neon, Supabase, Railway, etc.): paste the provider URL; many require ?sslmode=require on the query string.

JWT_SECRET="change-me-in-production-min-32-chars-long!!"
ADMIN_EMAIL="admin@novaflow.co.ke"
ADMIN_PASSWORD="changeme"
RESEND_API_KEY=""
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Production: use your public origin (https, no trailing slash). Drives canonical URLs, Open Graph, robots.txt, and sitemap.

# Cloudflare R2 (S3-compatible uploads).
# R2_PUBLIC_URL = public read base from R2 → bucket → Settings (Public development URL or custom domain).
# Must NOT be the S3 API endpoint (…r2.cloudflarestorage.com). No trailing slash. Example: https://pub-xxxxx.r2.dev
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Optional: extra hostnames allowed for next/image (comma-separated), e.g. a CDN in front of R2.
NEXT_PUBLIC_IMAGE_HOSTS=""
